# East Pass Outfitters — production environment variables
# Copy to .env (or set in Vercel project settings). When STRIPE_SECRET_KEY is
# unset, the app automatically falls back to the demo checkout flow.

# --- Stripe (payments) ---
# Secret API key (server only — never expose to the client).
STRIPE_SECRET_KEY=sk_live_xxx
# Webhook signing secret from the Stripe dashboard endpoint config.
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Set to "true" to enable Stripe Tax (automatic_tax). Requires Stripe Tax setup.
STRIPE_AUTOMATIC_TAX=false

# Public base URL used to build Checkout success/cancel redirect URLs.
PUBLIC_URL=https://www.eastpassoutfitters.com

# --- Database (Neon Postgres on Vercel) ---
# Pooled connection string (sslmode=require). Used by @neondatabase/serverless.
DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require

# --- Email (Resend) ---
# Transactional order-confirmation emails. No-op if unset.
RESEND_API_KEY=re_xxx
ORDER_FROM_EMAIL=East Pass Outfitters <orders@eastpassoutfitters.com>

# --- Admin login ---
# Owner password for the /#/admin dashboard. Logging in exchanges this for a
# session token. CHANGE THIS before going live.
ADMIN_PASSWORD=emeraldcoast2026

# --- Admin API (scripts/CI) ---
# Optional static shared secret for /api/admin/* via the x-admin-token header,
# independent of the login flow. Useful for automation. Leave unset if unused.
ADMIN_TOKEN=change-me-to-a-long-random-string
